{
	"compilerOptions": {
		"lib": ["dom", "ES2020"],
		"target": "ES2024",
		"strict": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"noEmit": true,
		"module": "preserve",
		"moduleResolution": "node"
	},
	"exclude": ["node_modules"]
}
